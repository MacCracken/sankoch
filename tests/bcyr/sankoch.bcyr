# sankoch — compression benchmarks
#
# Measures throughput and compression ratio for all algorithms
# across data sizes, input types, and compression levels.
#
# Output: one line per benchmark with name, input size, compressed size,
# ratio, total ns, and ns/byte.

include "src/lib.cyr"

var _bench_state = 0;
fn _bseed(s) { _bench_state = s; return 0; }
fn _bnext() {
    _bench_state = _bench_state * 6364136223846793005 + 1442695040888963407;
    return (_bench_state >> 33) & 255;
}

fn fill_zeros(buf, len) {
    var i = 0;
    while (i < len) { store8(buf + i, 0); i = i + 1; }
    return 0;
}

fn fill_text(buf, len) {
    var pat[46];
    store8(&pat+0,84);store8(&pat+1,104);store8(&pat+2,101);store8(&pat+3,32);
    store8(&pat+4,113);store8(&pat+5,117);store8(&pat+6,105);store8(&pat+7,99);
    store8(&pat+8,107);store8(&pat+9,32);store8(&pat+10,98);store8(&pat+11,114);
    store8(&pat+12,111);store8(&pat+13,119);store8(&pat+14,110);store8(&pat+15,32);
    store8(&pat+16,102);store8(&pat+17,111);store8(&pat+18,120);store8(&pat+19,32);
    store8(&pat+20,106);store8(&pat+21,117);store8(&pat+22,109);store8(&pat+23,112);
    store8(&pat+24,115);store8(&pat+25,32);store8(&pat+26,111);store8(&pat+27,118);
    store8(&pat+28,101);store8(&pat+29,114);store8(&pat+30,32);store8(&pat+31,116);
    store8(&pat+32,104);store8(&pat+33,101);store8(&pat+34,32);store8(&pat+35,108);
    store8(&pat+36,97);store8(&pat+37,122);store8(&pat+38,121);store8(&pat+39,32);
    store8(&pat+40,100);store8(&pat+41,111);store8(&pat+42,103);store8(&pat+43,46);
    store8(&pat+44,32);
    var i = 0;
    while (i < len) { store8(buf + i, load8(&pat + (i % 45))); i = i + 1; }
    return 0;
}

fn fill_random(buf, len) {
    _bseed(42);
    var i = 0;
    while (i < len) { store8(buf + i, _bnext()); i = i + 1; }
    return 0;
}

fn time_ns() {
    var ts[16];
    syscall(228, 1, &ts);
    return load64(&ts) * 1000000000 + load64(&ts + 8);
}

fn _strlen(s) {
    var i = 0;
    while (load8(s + i) != 0) { i = i + 1; }
    return i;
}

fn _print(s) {
    syscall(1, 1, s, _strlen(s));
    return 0;
}

fn _print_int(val) {
    if (val == 0) { _print("0"); return 0; }
    var buf[24];
    var neg = 0;
    var v = val;
    if (v < 0) { neg = 1; v = 0 - v; }
    var i = 23;
    while (v > 0) {
        store8(&buf + i, 48 + (v % 10));
        v = v / 10;
        i = i - 1;
    }
    if (neg == 1) { store8(&buf + i, 45); i = i - 1; }
    syscall(1, 1, &buf + i + 1, 23 - i);
    return 0;
}

fn _nl() { _print("\n"); return 0; }

# Run compress benchmark: returns compressed size.
fn bench_c(name, fmt, src, slen, dst, dcap, iters) {
    var clen = compress(fmt, src, slen, dst, dcap);
    if (clen < 0) { _print("  SKIP "); _print(name); _nl(); return 0 - 1; }
    var start = time_ns();
    var i = 0;
    while (i < iters) { compress(fmt, src, slen, dst, dcap); i = i + 1; }
    var elapsed = time_ns() - start;
    var ns_per = elapsed / iters;
    _print("  "); _print(name);
    _print("  in="); _print_int(slen);
    _print("  out="); _print_int(clen);
    _print("  ns/op="); _print_int(ns_per);
    _nl();
    return clen;
}

# Run compress_level benchmark.
fn bench_cl(name, fmt, src, slen, dst, dcap, iters, level) {
    var clen = compress_level(fmt, src, slen, dst, dcap, level);
    if (clen < 0) { _print("  SKIP "); _print(name); _nl(); return 0 - 1; }
    var start = time_ns();
    var i = 0;
    while (i < iters) { compress_level(fmt, src, slen, dst, dcap, level); i = i + 1; }
    var elapsed = time_ns() - start;
    var ns_per = elapsed / iters;
    _print("  "); _print(name);
    _print("  in="); _print_int(slen);
    _print("  out="); _print_int(clen);
    _print("  ns/op="); _print_int(ns_per);
    _nl();
    return clen;
}

# Run decompress benchmark: returns decompressed size.
fn bench_d(name, fmt, src, slen, dst, dcap, iters) {
    var dlen = decompress(fmt, src, slen, dst, dcap);
    if (dlen < 0) { _print("  SKIP "); _print(name); _nl(); return 0 - 1; }
    var start = time_ns();
    var i = 0;
    while (i < iters) { decompress(fmt, src, slen, dst, dcap); i = i + 1; }
    var elapsed = time_ns() - start;
    var ns_per = elapsed / iters;
    _print("  "); _print(name);
    _print("  in="); _print_int(slen);
    _print("  out="); _print_int(dlen);
    _print("  ns/op="); _print_int(ns_per);
    _nl();
    return dlen;
}

# LZ4 frame compress benchmark (direct — no FORMAT_LZ4F in the generic API).
fn bench_lz4f_c(name, src, slen, dst, dcap, iters) {
    var clen = lz4f_compress(src, slen, dst, dcap);
    if (clen < 0) { _print("  SKIP "); _print(name); _nl(); return 0 - 1; }
    var start = time_ns();
    var i = 0;
    while (i < iters) { lz4f_compress(src, slen, dst, dcap); i = i + 1; }
    var elapsed = time_ns() - start;
    var ns_per = elapsed / iters;
    _print("  "); _print(name);
    _print("  in="); _print_int(slen);
    _print("  out="); _print_int(clen);
    _print("  ns/op="); _print_int(ns_per);
    _nl();
    return clen;
}

# Run streaming compression once and return compressed length (no timing).
# Used to get SIZE lines for streaming output.
fn _bench_stream_sz(format, level, src, slen, dst, dcap, chunk_sz) {
    var ctx = stream_compress_init(format, level, dst, dcap);
    if (ctx == 0) { return 0 - 1; }
    var fed = 0;
    while (fed < slen) {
        var take = slen - fed;
        if (take > chunk_sz) { take = chunk_sz; }
        stream_write(ctx, src + fed, take);
        fed = fed + take;
    }
    return stream_compress_finish(ctx);
}

# Streaming-encoder benchmark via stream_compress_*. Feeds `slen` bytes
# in `chunk_sz`-sized pieces; measures ns/op for the full init/write*/finish
# sequence. Returns compressed length, or -1 on SKIP.
fn bench_stream(name, format, level, src, slen, dst, dcap, chunk_sz, iters) {
    var ctx = stream_compress_init(format, level, dst, dcap);
    if (ctx == 0) { _print("  SKIP "); _print(name); _nl(); return 0 - 1; }
    var fed = 0;
    while (fed < slen) {
        var take = slen - fed;
        if (take > chunk_sz) { take = chunk_sz; }
        stream_write(ctx, src + fed, take);
        fed = fed + take;
    }
    var clen = stream_compress_finish(ctx);
    if (clen < 0) { _print("  SKIP "); _print(name); _nl(); return 0 - 1; }

    var start = time_ns();
    var i = 0;
    while (i < iters) {
        ctx = stream_compress_init(format, level, dst, dcap);
        fed = 0;
        while (fed < slen) {
            var take = slen - fed;
            if (take > chunk_sz) { take = chunk_sz; }
            stream_write(ctx, src + fed, take);
            fed = fed + take;
        }
        stream_compress_finish(ctx);
        i = i + 1;
    }
    var elapsed = time_ns() - start;
    var ns_per = elapsed / iters;
    _print("  "); _print(name);
    _print("  in="); _print_int(slen);
    _print("  out="); _print_int(clen);
    _print("  ns/op="); _print_int(ns_per);
    _nl();
    return clen;
}

# Checksum benchmark.
fn bench_checksum(name, data, len, iters) {
    crc32_init_table();
    # Warmup
    adler32(data, len);
    crc32(data, len);

    var start = time_ns();
    var i = 0;
    if (load8(name) == 97) {
        # 'a' = adler
        while (i < iters) { adler32(data, len); i = i + 1; }
    } else {
        while (i < iters) { crc32(data, len); i = i + 1; }
    }
    var elapsed = time_ns() - start;
    var ns_per = elapsed / iters;
    _print("  "); _print(name);
    _print("  len="); _print_int(len);
    _print("  ns/op="); _print_int(ns_per);
    _nl();
    return 0;
}

# Emit one line: "SIZE <tag> <in> <out>" — machine-parseable by compare-sizes.sh
fn size_line(tag, inlen, outlen) {
    _print("SIZE ");
    _print(tag);
    _print(" ");
    _print_int(inlen);
    _print(" ");
    _print_int(outlen);
    _nl();
    return 0;
}

fn main() {
    alloc_init();

    var src1k = alloc(1024);
    var src4k = alloc(4096);
    var c = alloc(16384);
    var d = alloc(16384);
    var iters = 100;

    println("=== sankoch benchmarks ===");
    println("");

    # ---- Checksums ----
    println("--- Checksums (4KB, 100 iters) ---");
    fill_text(src4k, 4096);
    bench_checksum("adler32 4KB text", src4k, 4096, iters);
    bench_checksum("crc32   4KB text", src4k, 4096, iters);
    fill_text(src1k, 1024);
    bench_checksum("adler32 1KB text", src1k, 1024, 500);
    bench_checksum("crc32   1KB text", src1k, 1024, 500);
    println("");

    # ---- LZ4 ----
    println("--- LZ4 (100 iters) ---");
    fill_zeros(src1k, 1024);
    bench_c("lz4 c zeros 1K", FORMAT_LZ4, src1k, 1024, c, 16384, iters);
    fill_text(src1k, 1024);
    bench_c("lz4 c text  1K", FORMAT_LZ4, src1k, 1024, c, 16384, iters);
    fill_random(src1k, 1024);
    bench_c("lz4 c rand  1K", FORMAT_LZ4, src1k, 1024, c, 16384, iters);

    fill_text(src4k, 4096);
    bench_c("lz4 c text  4K", FORMAT_LZ4, src4k, 4096, c, 16384, iters);
    fill_zeros(src4k, 4096);
    bench_c("lz4 c zeros 4K", FORMAT_LZ4, src4k, 4096, c, 16384, iters);
    fill_random(src4k, 4096);
    bench_c("lz4 c rand  4K", FORMAT_LZ4, src4k, 4096, c, 16384, iters);

    # LZ4 decompress
    fill_text(src4k, 4096);
    var clen = lz4_compress(src4k, 4096, c, 16384);
    bench_d("lz4 d text  4K", FORMAT_LZ4, c, clen, d, 16384, iters);
    println("");

    # ---- LZ4F multi-block (v1.6.0) ----
    # 128K exercises the chunking loop (2 × 64KB blocks per frame).
    println("--- LZ4F multi-block (128K, 50 iters) ---");
    var lsrc128 = alloc(131072);
    var lc128   = alloc(135168);
    fill_text(lsrc128, 131072);
    bench_lz4f_c("lz4f c text 128K", lsrc128, 131072, lc128, 135168, 50);
    fill_random(lsrc128, 131072);
    bench_lz4f_c("lz4f c rand 128K", lsrc128, 131072, lc128, 135168, 50);
    println("");

    # ---- Streaming encoders (v1.7.0) ----
    # Feed 128K in 4K chunks through stream_compress_*. Throughput
    # includes the init/finish overhead on every iteration. The batch
    # equivalents above are the baseline.
    println("--- Streaming encoders (128K, 4K chunks, 50 iters) ---");
    var slc = alloc(262144);                 # dst sized for fixed-path random
    fill_text(lsrc128, 131072);
    bench_stream("stream deflate L1 text 128K", FORMAT_DEFLATE, 1, lsrc128, 131072, slc, 262144, 4096, 50);
    bench_stream("stream deflate L6 text 128K", FORMAT_DEFLATE, 6, lsrc128, 131072, slc, 262144, 4096, 50);
    bench_stream("stream zlib    L6 text 128K", FORMAT_ZLIB,    6, lsrc128, 131072, slc, 262144, 4096, 50);
    bench_stream("stream gzip    L6 text 128K", FORMAT_GZIP,    6, lsrc128, 131072, slc, 262144, 4096, 50);
    bench_stream("stream lz4f       text 128K", FORMAT_LZ4F,    0, lsrc128, 131072, slc, 262144, 4096, 50);
    fill_random(lsrc128, 131072);
    bench_stream("stream deflate L1 rand 128K", FORMAT_DEFLATE, 1, lsrc128, 131072, slc, 262144, 4096, 50);
    bench_stream("stream lz4f       rand 128K", FORMAT_LZ4F,    0, lsrc128, 131072, slc, 262144, 4096, 50);
    println("");

    # ---- DEFLATE per-level ----
    println("--- DEFLATE levels (4KB text, 50 iters) ---");
    fill_text(src4k, 4096);
    bench_cl("deflate L1 text 4K", FORMAT_DEFLATE, src4k, 4096, c, 16384, 50, 1);
    bench_cl("deflate L3 text 4K", FORMAT_DEFLATE, src4k, 4096, c, 16384, 50, 3);
    bench_cl("deflate L6 text 4K", FORMAT_DEFLATE, src4k, 4096, c, 16384, 50, 6);
    bench_cl("deflate L9 text 4K", FORMAT_DEFLATE, src4k, 4096, c, 16384, 50, 9);
    println("");

    # ---- DEFLATE input types ----
    println("--- DEFLATE input types (4KB, 50 iters) ---");
    fill_zeros(src4k, 4096);
    bench_c("deflate c zeros 4K", FORMAT_DEFLATE, src4k, 4096, c, 16384, 50);
    fill_text(src4k, 4096);
    bench_c("deflate c text  4K", FORMAT_DEFLATE, src4k, 4096, c, 16384, 50);
    fill_random(src4k, 4096);
    bench_c("deflate c rand  4K", FORMAT_DEFLATE, src4k, 4096, c, 16384, 50);

    # DEFLATE decompress
    fill_text(src4k, 4096);
    clen = deflate_compress(src4k, 4096, c, 16384);
    bench_d("deflate d text  4K", FORMAT_DEFLATE, c, clen, d, 16384, 50);
    fill_zeros(src4k, 4096);
    clen = deflate_compress(src4k, 4096, c, 16384);
    bench_d("deflate d zeros 4K", FORMAT_DEFLATE, c, clen, d, 16384, 50);
    println("");

    # ---- zlib ----
    println("--- zlib (4KB text, 50 iters) ---");
    fill_text(src4k, 4096);
    bench_c("zlib c text 4K", FORMAT_ZLIB, src4k, 4096, c, 16384, 50);
    clen = zlib_compress(src4k, 4096, c, 16384);
    bench_d("zlib d text 4K", FORMAT_ZLIB, c, clen, d, 16384, 50);
    bench_cl("zlib L1 text 4K", FORMAT_ZLIB, src4k, 4096, c, 16384, 50, 1);
    bench_cl("zlib L9 text 4K", FORMAT_ZLIB, src4k, 4096, c, 16384, 50, 9);
    println("");

    # ---- gzip ----
    println("--- gzip (4KB text, 50 iters) ---");
    fill_text(src4k, 4096);
    bench_c("gzip c text 4K", FORMAT_GZIP, src4k, 4096, c, 16384, 50);
    clen = gzip_compress(src4k, 4096, c, 16384);
    bench_d("gzip d text 4K", FORMAT_GZIP, c, clen, d, 16384, 50);
    bench_cl("gzip L1 text 4K", FORMAT_GZIP, src4k, 4096, c, 16384, 50, 1);
    bench_cl("gzip L9 text 4K", FORMAT_GZIP, src4k, 4096, c, 16384, 50, 9);
    println("");

    # ---- Size comparison (4KB text) ----
    println("--- Compression ratios (4KB text) ---");
    fill_text(src4k, 4096);

    clen = lz4_compress(src4k, 4096, c, 16384);
    _print("  lz4      "); _print_int(4096); _print(" -> "); _print_int(clen); _nl();

    clen = compress_level(FORMAT_DEFLATE, src4k, 4096, c, 16384, 1);
    _print("  defl L1  "); _print_int(4096); _print(" -> "); _print_int(clen); _nl();

    clen = compress_level(FORMAT_DEFLATE, src4k, 4096, c, 16384, 6);
    _print("  defl L6  "); _print_int(4096); _print(" -> "); _print_int(clen); _nl();

    clen = compress_level(FORMAT_DEFLATE, src4k, 4096, c, 16384, 9);
    _print("  defl L9  "); _print_int(4096); _print(" -> "); _print_int(clen); _nl();

    clen = zlib_compress(src4k, 4096, c, 16384);
    _print("  zlib     "); _print_int(4096); _print(" -> "); _print_int(clen); _nl();

    clen = gzip_compress(src4k, 4096, c, 16384);
    _print("  gzip     "); _print_int(4096); _print(" -> "); _print_int(clen); _nl();

    println("");

    # ================================================================
    # Machine-readable size comparison (parsed by scripts/compare-sizes.sh)
    # Covers 1K, 4K, 16K, 64K, 256K across text/zeros/random.
    # Output buffers sized to worst-case (input + 1K headroom).
    # ================================================================
    println("--- SIZE comparison ---");

    # Reusable large buffers — 256K input + 260K output
    var lsrc = alloc(262144);
    var lc   = alloc(270336);

    # ---- 1K text ----
    fill_text(lsrc, 1024);
    size_line("lz4_text_1K",     1024, lz4_compress(lsrc, 1024, lc, 270336));
    size_line("deflate1_text_1K",1024, deflate_compress_level(lsrc, 1024, lc, 270336, 1));
    size_line("deflate6_text_1K",1024, deflate_compress_level(lsrc, 1024, lc, 270336, 6));
    size_line("zlib6_text_1K",   1024, zlib_compress_level(lsrc, 1024, lc, 270336, 6));
    size_line("gzip6_text_1K",   1024, gzip_compress_level(lsrc, 1024, lc, 270336, 6));

    # ---- 4K text / zeros / random ----
    fill_text(lsrc, 4096);
    size_line("lz4_text_4K",     4096, lz4_compress(lsrc, 4096, lc, 270336));
    size_line("deflate1_text_4K",4096, deflate_compress_level(lsrc, 4096, lc, 270336, 1));
    size_line("deflate6_text_4K",4096, deflate_compress_level(lsrc, 4096, lc, 270336, 6));
    size_line("deflate9_text_4K",4096, deflate_compress_level(lsrc, 4096, lc, 270336, 9));
    size_line("zlib1_text_4K",   4096, zlib_compress_level(lsrc, 4096, lc, 270336, 1));
    size_line("zlib6_text_4K",   4096, zlib_compress_level(lsrc, 4096, lc, 270336, 6));
    size_line("gzip6_text_4K",   4096, gzip_compress_level(lsrc, 4096, lc, 270336, 6));

    fill_zeros(lsrc, 4096);
    size_line("deflate6_zeros_4K",4096, deflate_compress_level(lsrc, 4096, lc, 270336, 6));

    fill_random(lsrc, 4096);
    size_line("deflate6_rand_4K", 4096, deflate_compress_level(lsrc, 4096, lc, 270336, 6));

    # Random 64K / 256K — exercises the dynamic symbol-buffer overflow
    # path (v1.5.0 adaptive sub-block flushing). Pre-1.5.0 this fell
    # back to a single universal fixed-Huffman block; 1.5.0+ emits
    # multiple dynamic sub-blocks, each with a per-segment tree.
    fill_random(lsrc, 65536);
    size_line("deflate6_rand_64K", 65536, deflate_compress_level(lsrc, 65536, lc, 270336, 6));

    fill_random(lsrc, 262144);
    size_line("deflate6_rand_256K", 262144, deflate_compress_level(lsrc, 262144, lc, 270336, 6));

    # ---- 16K text ----
    fill_text(lsrc, 16384);
    size_line("lz4_text_16K",      16384, lz4_compress(lsrc, 16384, lc, 270336));
    size_line("deflate1_text_16K", 16384, deflate_compress_level(lsrc, 16384, lc, 270336, 1));
    size_line("deflate6_text_16K", 16384, deflate_compress_level(lsrc, 16384, lc, 270336, 6));
    size_line("zlib6_text_16K",    16384, zlib_compress_level(lsrc, 16384, lc, 270336, 6));
    size_line("gzip6_text_16K",    16384, gzip_compress_level(lsrc, 16384, lc, 270336, 6));

    # ---- 64K text ----
    fill_text(lsrc, 65536);
    size_line("lz4_text_64K",      65536, lz4_compress(lsrc, 65536, lc, 270336));
    size_line("deflate1_text_64K", 65536, deflate_compress_level(lsrc, 65536, lc, 270336, 1));
    size_line("deflate6_text_64K", 65536, deflate_compress_level(lsrc, 65536, lc, 270336, 6));
    size_line("zlib6_text_64K",    65536, zlib_compress_level(lsrc, 65536, lc, 270336, 6));
    size_line("gzip6_text_64K",    65536, gzip_compress_level(lsrc, 65536, lc, 270336, 6));

    # ---- LZ4F multi-block sizes (v1.6.0) ----
    # Exercises the 64KB chunking loop: 64K = 1 block, 128K = 2, 256K = 4.
    fill_text(lsrc, 65536);
    size_line("lz4f_text_64K",  65536,  lz4f_compress(lsrc, 65536,  lc, 270336));
    fill_text(lsrc, 131072);
    size_line("lz4f_text_128K", 131072, lz4f_compress(lsrc, 131072, lc, 270336));
    fill_random(lsrc, 131072);
    size_line("lz4f_rand_128K", 131072, lz4f_compress(lsrc, 131072, lc, 270336));

    # ---- 256K text ----
    fill_text(lsrc, 262144);
    size_line("lz4_text_256K",      262144, lz4_compress(lsrc, 262144, lc, 270336));
    size_line("deflate1_text_256K", 262144, deflate_compress_level(lsrc, 262144, lc, 270336, 1));
    size_line("deflate6_text_256K", 262144, deflate_compress_level(lsrc, 262144, lc, 270336, 6));
    size_line("zlib6_text_256K",    262144, zlib_compress_level(lsrc, 262144, lc, 270336, 6));
    size_line("gzip6_text_256K",    262144, gzip_compress_level(lsrc, 262144, lc, 270336, 6));
    size_line("lz4f_text_256K",     262144, lz4f_compress(lsrc, 262144, lc, 270336));

    # ---- Streaming SIZE comparison (v1.7.0) ----
    # Verifies that streaming output is in the same ballpark as batch.
    # Sizes can differ because block boundaries shift with window slides,
    # but should be within a few percent for text.
    fill_text(lsrc, 131072);
    size_line("stream_deflate6_text_128K", 131072, _bench_stream_sz(FORMAT_DEFLATE, 6, lsrc, 131072, lc, 270336, 4096));
    size_line("stream_zlib6_text_128K",    131072, _bench_stream_sz(FORMAT_ZLIB,    6, lsrc, 131072, lc, 270336, 4096));
    size_line("stream_gzip6_text_128K",    131072, _bench_stream_sz(FORMAT_GZIP,    6, lsrc, 131072, lc, 270336, 4096));
    size_line("stream_lz4f_text_128K",     131072, _bench_stream_sz(FORMAT_LZ4F,    0, lsrc, 131072, lc, 270336, 4096));

    println("--- END SIZE ---");
    println("");
    println("=== benchmarks complete ===");
    return 0;
}

var exit_code = main();
syscall(60, exit_code);
