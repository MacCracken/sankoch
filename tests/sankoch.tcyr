# sankoch — test suite
# Round-trip tests, known-vector tests, edge cases.

fn test_adler32_empty() {
    # Adler-32 of empty data = 1 (initial s1=1, s2=0)
    var buf[1];
    var result = adler32(buf, 0);
    assert(result == 1, "adler32 of empty data should be 1");
    return 0;
}

fn test_adler32_hello() {
    # Known value: adler32("Hello") = 0x058C01F5 = 93126133
    var buf[5];
    store8(buf + 0, 72);   # H
    store8(buf + 1, 101);  # e
    store8(buf + 2, 108);  # l
    store8(buf + 3, 108);  # l
    store8(buf + 4, 111);  # o
    var result = adler32(buf, 5);
    assert(result == 93126133, "adler32 of 'Hello'");
    return 0;
}

fn test_crc32_empty() {
    crc32_init_table();
    var buf[1];
    var result = crc32(buf, 0);
    # CRC-32 of empty data = 0x00000000
    assert(result == 0, "crc32 of empty data should be 0");
    return 0;
}

fn test_lz4_roundtrip_empty() {
    var src[1];
    var compressed[64];
    var decompressed[64];

    var clen = lz4_compress(src, 0, compressed, 64);
    assert(clen >= 0, "lz4 compress empty should succeed");

    var dlen = lz4_decompress(compressed, clen, decompressed, 64);
    assert(dlen == 0, "lz4 decompress empty should return 0 bytes");
    return 0;
}

fn test_lz4_roundtrip_small() {
    var src[16];
    var i = 0;
    while (i < 16) {
        store8(src + i, i + 65);  # "ABCDEFGHIJKLMNOP"
        i = i + 1;
    }

    var compressed[64];
    var decompressed[64];

    var clen = lz4_compress(src, 16, compressed, 64);
    assert(clen > 0, "lz4 compress should produce output");

    var dlen = lz4_decompress(compressed, clen, decompressed, 64);
    assert(dlen == 16, "lz4 roundtrip should produce 16 bytes");

    # Verify content
    i = 0;
    while (i < 16) {
        assert(load8(decompressed + i) == load8(src + i), "lz4 roundtrip content mismatch");
        i = i + 1;
    }
    return 0;
}

fn test_lz4_roundtrip_repetitive() {
    # Highly repetitive data — should compress well with hash match-finder
    var src[256];
    var i = 0;
    while (i < 256) {
        store8(src + i, i % 4);  # repeating 0,1,2,3 pattern
        i = i + 1;
    }

    var compressed[512];
    var decompressed[512];

    var clen = lz4_compress(src, 256, compressed, 512);
    assert(clen > 0, "lz4 compress repetitive should succeed");
    # With matches the compressed size should be smaller than input
    assert(clen < 256, "lz4 should compress repetitive data");

    var dlen = lz4_decompress(compressed, clen, decompressed, 512);
    assert(dlen == 256, "lz4 roundtrip repetitive should restore 256 bytes");

    i = 0;
    while (i < 256) {
        assert(load8(decompressed + i) == load8(src + i), "lz4 repetitive content mismatch");
        i = i + 1;
    }
    return 0;
}

fn test_lz4_roundtrip_all_same() {
    # All identical bytes — maximum compression opportunity
    var src[128];
    var i = 0;
    while (i < 128) {
        store8(src + i, 42);
        i = i + 1;
    }

    var compressed[256];
    var decompressed[256];

    var clen = lz4_compress(src, 128, compressed, 256);
    assert(clen > 0, "lz4 compress all-same should succeed");
    assert(clen < 128, "lz4 should compress all-same data");

    var dlen = lz4_decompress(compressed, clen, decompressed, 256);
    assert(dlen == 128, "lz4 roundtrip all-same should restore 128 bytes");

    i = 0;
    while (i < 128) {
        assert(load8(decompressed + i) == 42, "lz4 all-same content mismatch");
        i = i + 1;
    }
    return 0;
}

fn test_lz4_roundtrip_short() {
    # 1-3 bytes — below minimum match length, must go literals-only
    var src[3];
    store8(src + 0, 10);
    store8(src + 1, 20);
    store8(src + 2, 30);

    var compressed[64];
    var decompressed[64];

    var clen = lz4_compress(src, 3, compressed, 64);
    assert(clen > 0, "lz4 compress 3 bytes should succeed");

    var dlen = lz4_decompress(compressed, clen, decompressed, 64);
    assert(dlen == 3, "lz4 roundtrip 3 bytes");
    assert(load8(decompressed + 0) == 10, "lz4 short byte 0");
    assert(load8(decompressed + 1) == 20, "lz4 short byte 1");
    assert(load8(decompressed + 2) == 30, "lz4 short byte 2");
    return 0;
}

fn test_lz4_buffer_too_small() {
    var src[16];
    var i = 0;
    while (i < 16) {
        store8(src + i, 42);
        i = i + 1;
    }

    var compressed[64];
    var clen = lz4_compress(src, 16, compressed, 64);
    assert(clen > 0, "compress should succeed");

    # Try to decompress into too-small buffer
    var tiny[4];
    var dlen = lz4_decompress(compressed, clen, tiny, 4);
    assert(dlen < 0, "decompress into tiny buffer should fail");
    return 0;
}

fn test_detect_format_gzip() {
    var buf[2];
    store8(buf + 0, 31);   # 0x1f
    store8(buf + 1, 139);  # 0x8b
    var fmt = detect_format(buf, 2);
    assert(fmt == FORMAT_GZIP, "should detect gzip");
    return 0;
}

fn test_detect_format_zlib() {
    # zlib: CMF=0x78 (deflate, window=32K), FLG=0x9C
    # (0x78 * 256 + 0x9C) % 31 == 0
    var buf[2];
    store8(buf + 0, 120);  # 0x78
    store8(buf + 1, 156);  # 0x9C
    var fmt = detect_format(buf, 2);
    assert(fmt == FORMAT_ZLIB, "should detect zlib");
    return 0;
}

# ================================================================
# DEFLATE decompression tests (known vectors from zlib)
# ================================================================

fn test_deflate_empty() {
    # Raw DEFLATE of empty input: 0x03 0x00
    # (BFINAL=1, BTYPE=01 fixed Huffman, symbol 256 = end of block)
    var src[2];
    store8(src + 0, 3);
    store8(src + 1, 0);

    var dst[64];
    var dlen = deflate_decompress(src, 2, dst, 64);
    assert(dlen == 0, "deflate empty should decompress to 0 bytes");
    return 0;
}

fn test_deflate_hello() {
    # Raw DEFLATE of "Hello" (fixed Huffman, level 1):
    # 243 72 205 201 201 7 0
    var src[7];
    store8(src + 0, 243);
    store8(src + 1, 72);
    store8(src + 2, 205);
    store8(src + 3, 201);
    store8(src + 4, 201);
    store8(src + 5, 7);
    store8(src + 6, 0);

    var dst[64];
    var dlen = deflate_decompress(src, 7, dst, 64);
    assert(dlen == 5, "deflate Hello should be 5 bytes");
    assert(load8(dst + 0) == 72, "deflate Hello[0] = H");
    assert(load8(dst + 1) == 101, "deflate Hello[1] = e");
    assert(load8(dst + 2) == 108, "deflate Hello[2] = l");
    assert(load8(dst + 3) == 108, "deflate Hello[3] = l");
    assert(load8(dst + 4) == 111, "deflate Hello[4] = o");
    return 0;
}

fn test_deflate_stored() {
    # Raw DEFLATE of "ABCD" stored (uncompressed block):
    # 1 4 0 251 255 65 66 67 68
    var src[9];
    store8(src + 0, 1);    # BFINAL=1, BTYPE=00 (stored)
    store8(src + 1, 4);    # LEN low
    store8(src + 2, 0);    # LEN high
    store8(src + 3, 251);  # NLEN low
    store8(src + 4, 255);  # NLEN high
    store8(src + 5, 65);   # A
    store8(src + 6, 66);   # B
    store8(src + 7, 67);   # C
    store8(src + 8, 68);   # D

    var dst[64];
    var dlen = deflate_decompress(src, 9, dst, 64);
    assert(dlen == 4, "deflate stored ABCD should be 4 bytes");
    assert(load8(dst + 0) == 65, "deflate stored[0] = A");
    assert(load8(dst + 1) == 66, "deflate stored[1] = B");
    assert(load8(dst + 2) == 67, "deflate stored[2] = C");
    assert(load8(dst + 3) == 68, "deflate stored[3] = D");
    return 0;
}

fn test_deflate_backreference() {
    # Raw DEFLATE of "ABCABCABCABCABCABC" (dynamic Huffman, level 6):
    # 115 116 114 118 68 69 0
    var src[7];
    store8(src + 0, 115);
    store8(src + 1, 116);
    store8(src + 2, 114);
    store8(src + 3, 118);
    store8(src + 4, 68);
    store8(src + 5, 69);
    store8(src + 6, 0);

    var dst[64];
    var dlen = deflate_decompress(src, 7, dst, 64);
    assert(dlen == 18, "deflate ABC*6 should be 18 bytes");

    # Verify: "ABCABCABCABCABCABC"
    var i = 0;
    while (i < 18) {
        var expected = 65 + (i % 3);  # A=65, B=66, C=67
        assert(load8(dst + i) == expected, "deflate backreference content");
        i = i + 1;
    }
    return 0;
}

fn test_deflate_via_api() {
    # Test through the public decompress() API
    var src[2];
    store8(src + 0, 3);
    store8(src + 1, 0);

    var dst[64];
    var dlen = decompress(FORMAT_DEFLATE, src, 2, dst, 64);
    assert(dlen == 0, "decompress(DEFLATE) should work through public API");
    return 0;
}

# ================================================================
# DEFLATE compression round-trip tests (Phase 3)
# ================================================================

fn test_deflate_roundtrip_empty() {
    var src[1];
    var compressed[64];
    var decompressed[64];

    var clen = deflate_compress(src, 0, compressed, 64);
    assert(clen > 0, "deflate compress empty should produce output");

    var dlen = deflate_decompress(compressed, clen, decompressed, 64);
    assert(dlen == 0, "deflate roundtrip empty should be 0 bytes");
    return 0;
}

fn test_deflate_roundtrip_hello() {
    var src[5];
    store8(src + 0, 72);   # H
    store8(src + 1, 101);  # e
    store8(src + 2, 108);  # l
    store8(src + 3, 108);  # l
    store8(src + 4, 111);  # o

    var compressed[64];
    var decompressed[64];

    var clen = deflate_compress(src, 5, compressed, 64);
    assert(clen > 0, "deflate compress Hello should succeed");

    var dlen = deflate_decompress(compressed, clen, decompressed, 64);
    assert(dlen == 5, "deflate roundtrip Hello should be 5 bytes");
    assert(load8(decompressed + 0) == 72, "deflate rt Hello[0]");
    assert(load8(decompressed + 1) == 101, "deflate rt Hello[1]");
    assert(load8(decompressed + 2) == 108, "deflate rt Hello[2]");
    assert(load8(decompressed + 3) == 108, "deflate rt Hello[3]");
    assert(load8(decompressed + 4) == 111, "deflate rt Hello[4]");
    return 0;
}

fn test_deflate_roundtrip_repetitive() {
    # "ABCABCABC..." — 120 bytes, should get back-references
    var src[120];
    var i = 0;
    while (i < 120) {
        store8(src + i, 65 + (i % 3));
        i = i + 1;
    }

    var compressed[256];
    var decompressed[256];

    var clen = deflate_compress(src, 120, compressed, 256);
    assert(clen > 0, "deflate compress repetitive should succeed");
    assert(clen < 120, "deflate should compress repetitive data");

    var dlen = deflate_decompress(compressed, clen, decompressed, 256);
    assert(dlen == 120, "deflate roundtrip repetitive should restore 120 bytes");

    i = 0;
    while (i < 120) {
        assert(load8(decompressed + i) == load8(src + i), "deflate repetitive content");
        i = i + 1;
    }
    return 0;
}

# ================================================================
# zlib wrapper tests (Phase 4)
# ================================================================

fn test_zlib_roundtrip_hello() {
    var src[5];
    store8(src + 0, 72);
    store8(src + 1, 101);
    store8(src + 2, 108);
    store8(src + 3, 108);
    store8(src + 4, 111);

    var compressed[128];
    var decompressed[64];

    var clen = zlib_compress(src, 5, compressed, 128);
    assert(clen > 0, "zlib compress Hello should succeed");

    # Verify it starts with a valid zlib header
    var cmf = load8(compressed);
    assert((cmf & 15) == 8, "zlib header CM should be 8");
    var check = load8(compressed) * 256 + load8(compressed + 1);
    assert((check % 31) == 0, "zlib header checksum");

    var dlen = zlib_decompress(compressed, clen, decompressed, 64);
    assert(dlen == 5, "zlib roundtrip Hello should be 5 bytes");
    assert(load8(decompressed + 0) == 72, "zlib rt Hello[0]");
    assert(load8(decompressed + 4) == 111, "zlib rt Hello[4]");
    return 0;
}

fn test_zlib_roundtrip_via_api() {
    var src[5];
    store8(src + 0, 72);
    store8(src + 1, 101);
    store8(src + 2, 108);
    store8(src + 3, 108);
    store8(src + 4, 111);

    var compressed[128];
    var decompressed[64];

    var clen = compress(FORMAT_ZLIB, src, 5, compressed, 128);
    assert(clen > 0, "zlib compress via API should succeed");

    var dlen = decompress(FORMAT_ZLIB, compressed, clen, decompressed, 64);
    assert(dlen == 5, "zlib decompress via API should succeed");
    return 0;
}

# ================================================================
# gzip wrapper tests (Phase 4)
# ================================================================

fn test_gzip_roundtrip_hello() {
    var src[5];
    store8(src + 0, 72);
    store8(src + 1, 101);
    store8(src + 2, 108);
    store8(src + 3, 108);
    store8(src + 4, 111);

    var compressed[128];
    var decompressed[64];

    var clen = gzip_compress(src, 5, compressed, 128);
    assert(clen > 0, "gzip compress Hello should succeed");

    # Verify gzip magic
    assert(load8(compressed) == 31, "gzip magic byte 0");
    assert(load8(compressed + 1) == 139, "gzip magic byte 1");
    assert(load8(compressed + 2) == 8, "gzip CM = deflate");

    var dlen = gzip_decompress(compressed, clen, decompressed, 64);
    assert(dlen == 5, "gzip roundtrip Hello should be 5 bytes");
    assert(load8(decompressed + 0) == 72, "gzip rt Hello[0]");
    assert(load8(decompressed + 4) == 111, "gzip rt Hello[4]");
    return 0;
}

fn test_gzip_roundtrip_via_api() {
    var src[5];
    store8(src + 0, 72);
    store8(src + 1, 101);
    store8(src + 2, 108);
    store8(src + 3, 108);
    store8(src + 4, 111);

    var compressed[128];
    var decompressed[64];

    var clen = compress(FORMAT_GZIP, src, 5, compressed, 128);
    assert(clen > 0, "gzip compress via API should succeed");

    var dlen = decompress(FORMAT_GZIP, compressed, clen, decompressed, 64);
    assert(dlen == 5, "gzip decompress via API should succeed");
    return 0;
}

fn test_format_roundtrip_detect() {
    # Compress as zlib, then auto-detect the format
    var src[5];
    store8(src + 0, 72);
    store8(src + 1, 101);
    store8(src + 2, 108);
    store8(src + 3, 108);
    store8(src + 4, 111);

    var zbuf[128];
    var gbuf[128];
    var zlen = zlib_compress(src, 5, zbuf, 128);
    var glen = gzip_compress(src, 5, gbuf, 128);

    var zfmt = detect_format(zbuf, zlen);
    assert(zfmt == FORMAT_ZLIB, "detect_format should identify zlib output");

    var gfmt = detect_format(gbuf, glen);
    assert(gfmt == FORMAT_GZIP, "detect_format should identify gzip output");
    return 0;
}

fn main() {
    test_adler32_empty();
    test_adler32_hello();
    test_crc32_empty();
    test_lz4_roundtrip_empty();
    test_lz4_roundtrip_small();
    test_lz4_roundtrip_repetitive();
    test_lz4_roundtrip_all_same();
    test_lz4_roundtrip_short();
    test_lz4_buffer_too_small();
    test_detect_format_gzip();
    test_detect_format_zlib();
    test_deflate_empty();
    test_deflate_hello();
    test_deflate_stored();
    test_deflate_backreference();
    test_deflate_via_api();
    test_deflate_roundtrip_empty();
    test_deflate_roundtrip_hello();
    test_deflate_roundtrip_repetitive();
    test_zlib_roundtrip_hello();
    test_zlib_roundtrip_via_api();
    test_gzip_roundtrip_hello();
    test_gzip_roundtrip_via_api();
    test_format_roundtrip_detect();

    println("sankoch: all tests passed");
    return 0;
}

var exit_code = main();
syscall(60, exit_code);
